model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String   
  userId      String?  @map("user_id")
  description String?  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}