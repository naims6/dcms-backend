model Teacher {
  id             String   @id @default(uuid())

  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])

  name           String
  phone          String
  designation    String
  joinDate       DateTime
  bio            String?
  photo          String?
  experience     String?
  specialization String?
  gender         String?
  isActive       Boolean @default(true)

  createdAt      DateTime @default(now())
}