
model Guardian {
  id           String             @id @default(uuid())

  studentId    String

  name         String
  relation     GuardianRelation

  phone        String
  email        String?

  occupation   String?

  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([phone])
}