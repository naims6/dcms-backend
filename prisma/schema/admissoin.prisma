model Admission {
  id                String   @id @default(uuid())

  // Student Information
  fullName          String
  dateOfBirth       DateTime
  gender            Gender
  bloodGroup        String?
  religion          String
  studentPhoto      String?   // image URL

  // Academic Information
  classApplying     String
  previousSchool    String
  previousClass     String
  previousGrade     String

  // Father তথ্য
  fatherName        String
  fatherOccupation  String
  fatherPhone       String

  // Mother তথ্য
  motherName        String
  motherOccupation  String
  motherPhone       String

  // Contact Information
  address           String
  city              String
  postalCode        String
  email             String
  emergencyContact  String

  // Additional
  guardianName      String?
  specialNotes      String?

  // System Fields
  status            AdmissionStatus @default(PENDING)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}