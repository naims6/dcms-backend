model Admission {
  id             String            @id @default(uuid())

  studentId      String
  applicationId  String            @unique

  status         AdmissionStatus   @default(PENDING)

  appliedDate    DateTime          @default(now())
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
}