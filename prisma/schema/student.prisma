model Student {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])

  registrationId   String   @unique
  pinHash          String

  name             String
  phone            String
  address          String
  gender           String
  dateOfBirth      DateTime

  admissionDate    DateTime
  status           StudentStatus @default(ACTIVE)
}