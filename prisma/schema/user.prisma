model User {
  id          String    @id @default(uuid())
  fullName    String
  dateOfBirth DateTime
  gender      Gender
  bloodGroup  String
  religion    String
  email       String    @unique
  phone       String    @unique
  password    String
  roleId      Int
  isActive    Boolean   @default(false)
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  address     Address?
  admin       Admin?
  otp         Otp[]
  sessions    Session[]
  student     Student?
  teacher     Teacher?
  auditLogs   AuditLog[]

  // relations
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([roleId])
  @@index([email])
  @@index([phone])
}

model Session {
  id           String   @id @default(uuid())
  sessionId    String   @unique
  expiresIn    DateTime
  refreshToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Otp {
  id        String   @id @default(uuid())
  hashOtp   String
  expiresIn DateTime
  type      OtpType
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}
