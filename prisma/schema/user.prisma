model User {
  id        String   @id @default(uuid())

  fullName      String
  dateOfBirth   DateTime
  gender        Gender
  bloodGroup    String
  religion      String

  email         String   @unique
  phone         String   @unique
  password      String

  role      Role

  isActive  Boolean  @default(false)

  student   Student?
  teacher   Teacher?
  admin     Admin?
  address   Address?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([email])
}
