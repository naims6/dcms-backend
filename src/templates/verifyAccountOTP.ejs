<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="format-detection"
      content="telephone=no,date=no,address=no,email=no,url=no"
    />

    <title>OTP Verification</title>

    <style>
      body {
        margin: 0;
        padding: 24px 16px;
        background: #f4f7fb;
        font-family: Arial, Helvetica, sans-serif;
        color: #1e293b;
      }

      .wrapper {
        max-width: 500px;
        margin: auto;
        background: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
      }

      .header {
        background: #1e3a8a;
        color: white;
        text-align: center;
        padding: 32px 24px;
      }

      .header h1 {
        margin: 0;
        font-size: 28px;
      }

      .header p {
        margin-top: 10px;
        font-size: 14px;
        opacity: 0.9;
      }

      .content {
        padding: 32px 24px;
        text-align: center;
      }

      .hello {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 14px;
      }

      .message {
        font-size: 15px;
        line-height: 1.7;
        color: #475569;
        margin-bottom: 28px;
      }

      .otp-box {
        background: #f8fafc;
        border: 2px dashed #cbd5e1;
        border-radius: 16px;
        padding: 24px 20px;
        margin-bottom: 20px;
      }

      .otp-label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #64748b;
        margin-bottom: 12px;
      }

      .otp-code {
        font-size: 42px;
        font-weight: bold;
        letter-spacing: 10px;
        color: #0f172a;
        user-select: all;
        -webkit-user-select: all;
      }

      .info {
        background: #eff6ff;
        color: #1d4ed8;
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 14px;
        margin-bottom: 18px;
      }

      .warning {
        background: #fff7ed;
        color: #c2410c;
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.6;
      }

      .footer {
        border-top: 1px solid #e2e8f0;
        padding: 24px;
        text-align: center;
        font-size: 12px;
        color: #64748b;
      }

      .footer strong {
        color: #0f172a;
      }

      @media only screen and (max-width: 520px) {
        .otp-code {
          font-size: 32px;
          letter-spacing: 6px;
        }

        .content {
          padding: 24px 18px;
        }
      }
    </style>
  </head>

  <body>
    <div class="wrapper">

      <!-- Header -->
      <div class="header">
        <h1>Email Verification</h1>
        <p>Secure One-Time Password</p>
      </div>

      <!-- Content -->
      <div class="content">

        <div class="hello">
          Hello, <%= fullName || "Applicant" %>
        </div>

        <div class="message">
          Use the verification code below to complete your account verification.
        </div>

        <!-- OTP -->
        <div class="otp-box">
          <div class="otp-label">
            Your OTP Code
          </div>

          <div class="otp-code">
            <%= otp %>
          </div>
        </div>

        <!-- Info -->
        <div class="info">
          ⏰ This OTP will expire in 5 minutes.
        </div>

        <!-- Warning -->
        <div class="warning">
          🔒 Never share your OTP with anyone. Our team will never ask for it.
        </div>

      </div>

      <!-- Footer -->
      <div class="footer">
        <strong>Dhanbari Collegiate Model School</strong>
        <br /><br />
        © <%= new Date().getFullYear() %> All rights reserved.
      </div>
    </div>
  </body>
</html>
